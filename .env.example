# Google Firebase Configuration (Frontend)
# Get these from your Firebase Project Settings: https://console.firebase.google.com/
# Set as VITE_* variables in Vercel (Settings → Environment Variables)

VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# Google Gemini API Key (Backend/API Route)
# Get it from: https://ai.google.dev/
# Set as GEMINI_API_KEY (NO VITE_ prefix) in Vercel
# This is only accessible server-side (in api/gemini.ts), never exposed to client
GEMINI_API_KEY=your_gemini_api_key_here

# App Configuration (for local development)
VITE_APP_URL=http://localhost:3000
